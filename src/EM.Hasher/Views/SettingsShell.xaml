<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="EM.Hasher.Views.SettingsShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkitConverters="using:CommunityToolkit.WinUI.Converters"
    NavigationCacheMode="Required"
    mc:Ignorable="d">
    <Page.Resources>
        <toolkitConverters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Settings Breadcrumb Header  -->
        <StackPanel
            Grid.Row="0"
            Margin="10,0,0,0"
            Orientation="Horizontal">
            <TextBlock
                Margin="1,8,0,4"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="Settings"
                Tapped="OnSettingsBreadcrumbTapped" />
            <TextBlock
                Margin="6,8,5,4"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="&gt;"
                Visibility="{x:Bind UiStateViewModel.IsSettingsSubPageVisible, Converter={StaticResource BoolToVisibility}, Mode=OneWay}" />
            <TextBlock
                Margin="1,8,0,4"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="{x:Bind UiStateViewModel.SettingsSubPageTitle, Mode=OneWay}"
                Visibility="{x:Bind UiStateViewModel.IsSettingsSubPageVisible, Converter={StaticResource BoolToVisibility}, Mode=OneWay}" />
        </StackPanel>

        <!--  Settings Content Frame  -->
        <Frame
            x:Name="settingsFrame"
            Grid.Row="1"
            Margin="0,0,0,0"
            Padding="10"
            Background="Transparent"
            Navigated="SettingsFrame_Navigated" />
    </Grid>
</Page>
